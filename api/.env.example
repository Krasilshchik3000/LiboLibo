# Postgres connection string.
# Локально (Docker Compose) — ставится автоматически из docker-compose.yml.
# На Railway — подставляется автоматически из плагина Postgres
# (используй reference variable `${{Postgres.DATABASE_URL}}` при настройке сервиса).
DATABASE_URL=postgres://libolibo:libolibo@db:5432/libolibo

# Порт локального HTTP-сервера. На Railway игнорируется — платформа
# подставляет PORT сама.
PORT=3000

# Секреты Transistor лежат в отдельном файле transistor.env (не в этом).
# Шаблон — transistor.env.example.

# Voice comments — directory where uploaded m4a files are written. На
# Railway указывает на Volume mount (/data/comments). Локально по
# умолчанию /tmp/libolibo-comments если переменная не задана.
COMMENTS_AUDIO_DIR=/tmp/libolibo-comments
